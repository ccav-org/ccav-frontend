# ===== CCAV Express API Server — 环境变量配置 =====
# 将此文件复制为 .env 并填入真实值
# cp .env.example .env
#
# 注意：.env 文件已通过 .gitignore 排除，不会提交到仓库。
# 若 server/.env 不存在，server 将跳过加载（不影响启动）。

# ============ Required ============
# JWT 签名密钥
# 缺失时 server 拒绝启动并提示错误信息。
# 开发环境可用任意 32 字符以上字符串。
# 生产环境必须使用固定密钥，否则每次重启会导致所有已签发 token 失效。
JWT_SECRET=replace-with-at-least-32-character-secret

# ============ Provider API Keys ============
# 均为可选。缺失时对应路由启动 warning，server 正常运行。

# Kimi / Moonshot API Key — 用于 /api/optimize 和 /api/kimi/chat
KIMI_API_KEY=sk-your-kimi-api-key

# 可灵(Kling) Access Key + Secret Key — 用于 /api/kling/*
KLING_ACCESS_KEY=your-kling-access-key
KLING_SECRET_KEY=your-kling-secret-key

# Replicate API Key — 用于 /api/replicate/* (当前未正式启用)
REPLICATE_API_KEY=r8-your-replicate-api-key

# ============ Optional ============
# API 端口（默认 3001）
# API_PORT=3001

# 短信验证码服务（当前未接入真实短信通道）
# SMS_API_KEY=***
